[
    {
        "name": "2026 Scouting App",
        "description": "Team 4099: The Falcon's 2026 scouting data collection page",
        "components": [
            {
                "type": "GenericHeaderOne",
                "text": "2026 Scouting App"
            },
            {
                "type": "GenericHeaderTwo",
                "text": "Match Info"
            },
            {
                "type": "GenericTextInput",
                "text": "Scout Name",
                "placeholder": [
                    "shayaan"
                ],
                "id": "ScoutId",
                "required": true
            },
            {
                "type": "DropdownTextInput",
                "text": "Match Key",
                "options": [
                    "qm",
                    "qf",
                    "sf",
                    "f"
                ],
                "placeholder": [
                    "number"
                ],
                "id": "MatchKey",
                "required": true
            },
            {
                "type": "GenericRadioSelect",
                "text": "Alliance",
                "options": [
                    "red",
                    "blue"
                ],
                "id": "Alliance",
                "required": true
            },
            {
                "type": "GenericDropdown",
                "text": "Driver Station",
                "options": [
                    "1",
                    "2",
                    "3"
                ],
                "id": "DriverStation",
                "required": true
            },
            {
                "type": "GenericTextInput",
                "text": "Team Number",
                "placeholder": [
                    "4099"
                ],
                "id": "TeamNumber",
                "required": true
            },
            {
                "type": "RobotImage"
            },
            {
                "type": "Spacing"
            },
            {
                "type": "GenericHeaderTwo",
                "text": "Auto"
            },
            {
                "type": "GenericDropdown",
                "text": "Robot Starting Position",
                "options": [
                    "Depot Side, under TRENCH",
                    "Depot Side, on BUMP",
                    "Center",
                    "Human-Player Side on TRENCH",
                    "Human-Player Side, on BUMP"
                ],
                "id": "StartingPosition",
                "required": true
            },
            {
                "type": "GenericCheckboxSelect",
                "text": "Where do they score in AUTO?",
                "options": [
                    "Centered, near Driver Station",
                    "Centered, flush with HUB",
                    "Depot Side, near Driver Station",
                    "Depot Side, near TRENCH",
                    "Human Player Side, near Driver Station",
                    "Human Player Side, near TRENCH"
                ],
                "id": "AutoScoringSide",
                "required": true
            },
            {
              "type": "GenericCheckboxSelect",
              "text": "How do they traverse to the NEUTRAL ZONE in AUTO?",
              "options": [
                "Over the BUMP",
                "Through the TRENCH"
              ],
              "id": "AutoTrenchBump",
              "required": true
            },
            {
              "type": "GenericToggle",
              "text": "Did they climb in Auto?",
              "id": "AutoClimb"
            },
            {
                "type": "GenericTextArea",
                "text": "General Auto Notes",
                "id": "AutoNotes"
            },
            {
                "type": "Spacing"
            },
            {
                "type": "GenericHeaderTwo",
                "text": "Teleop"
            },
            {
              "type": "GenericCheckboxSelect",
              "text": "Where do they score in TELEOP?",
              "options": [
                "Centered, near Driver Station",
                "Centered, flush with HUB",
                "Depot Side, near Driver Station",
                "Depot Side, near TRENCH",
                "Human Player Side, near Driver Station",
                "Human Player Side, near TRENCH"
              ],
              "id": "TeleopScoringSide",
              "required": true
            },
            {
              "type": "GenericToggle",
              "text": "Do they shoot while moving?",
              "id": "ShootOnTheMove",
              "required": true
            },
            {
              "type": "GenericCheckboxSelect",
              "text": "How do they traverse to the NEUTRAL ZONE in TELEOP?",
              "options": [
                "Over the BUMP",
                "Through the TRENCH"
              ],
              "id": "TeleopTrenchBump",
              "required": true
            },
            {
                "type": "GenericDropdown",
                "text": "Did the robot climb in teleop?",
                "options": [
                    "No climb",
                    "L1",
                    "L2",
                    "L3"
                ],
                "id": "TeleopClimb",
                "required": true
            },
            {
                "type": "GenericDropdown",
                "text": "How long did it take to climb to said level, including alignment?",
                "options": [
                    ">20 seconds",
                    "10-20 seconds",
                    "5-10 seconds",
                    "<5 seconds"
                ],
                "id": "ClimbSpeed"
            },
            {
              "type": "GenericTextArea",
              "text": "Teleop Notes",
              "id": "TeleopNotes"
            },
            {
                "type": "Spacing"
            },
            {
                "type": "GenericHeaderTwo",
                "text": "Ratings"
            },
            {
                "type": "GenericToggle",
                "text": "Did they disable?",
                "id": "Disabled"
            },
            {
            "type": "GenericDropdown",
                "text": "How tippy was their robot?",
                "options": [
                    "Very tippy",
                    "Moderately tippy",
                    "Stable"
                ],
                "id": "StabilityRating",
                "required": true
            },
            {
              "type": "GenericCheckboxSelect",
              "text": "What roles do they play?",
              "options": [
                "Shooter, dumper",
                "Shooter, sprinter",
                "Passer",
                "Shover",
                "Defense"
              ],
              "id": "RobotStyleType",
              "required": true
            },
            {
                "type": "GenericDropdown",
                "text": "How fluid was their driving?",
                "options": [
                    "Very Fluid: Swerved past obstacles and had no delays when reaching their destination.",
                    "Fluid: Ran into obstacles at times but generally very fluid & consistent.",
                    "Average: Vulnerable to defense & would hit obstacles.",
                    "Poor: Easily impacted by other robots & obstacles and inconsistent when driving.",
                    "Very Poor: Pinballed into other robots / racked up fouls / hampered their alliance."
                ],
                "id": "DriverRating",
                "required": true
            },
            {
                "type": "GenericDropdown",
                "text": "How fast did they intake?",
                "options": [
                    "Very Fast",
                    "Fast",
                    "Average",
                    "Slow",
                    "Very Slow"
                ],
                "id": "IntakeSpeed"
            },
            {
                "type": "GenericDropdown",
                "text": "How fast was their throughput?",
                "options": [
                    "Very Good: Finished outtaking in 0-5 seconds",
                    "Good: Finished outtaking in 5-10 seconds",
                    "Okay: Finished outtaking in 10-15 seconds",
                    "Poor: Finished outtaking in 15-20 seconds",
                    "Very Poor: Spent the entire shift outtaking"
                ],
                "id": "ThroughputSpeed"
            },
            {
                "type": "GenericDropdown",
                "text": "How good are they at defending?",
                "options": [
                    "Very Good: Severely impacted robot's intaking/scoring ability",
                    "Good: Heavily impacted robot's intaking/scoring ability",
                    "Okay: Mildly impacted robot's intaking/scoring ability",
                    "Poor: Barely impacted robot's intaking/scoring ability",
                    "Very Poor: Did not impact robot's intaking/scoring ability"
                ],
                "id": "DefenseRating"
            },
            {
                "type": "GenericDropdown",
                "text": "How good are they at intaking while being defended?",
                "options": [
                    "Very Good:  Little to no impact on the robot's intaking ability",
                    "Good: Some impact on robot's intaking ability",
                    "Okay: Notable impact on robot's intaking ability",
                    "Poor: Heavy impact on the robot's intaking ability",
                    "Very Poor: Robot's intaking ability severely hampered, barely held onto the game pieces"
                ],
                "id": "IntakeDefenseRating"
            },
            {
                "type": "GenericDropdown",
                "text": "How good are they at shooting while being defended?",
                "options": [
                    "Very Good:  Little to no impact on the robot's shooting ability",
                    "Good: Some impact on robot's shooting ability",
                    "Okay: Notable impact on robot's shooting ability",
                    "Poor: Heavy impact on the robot's shooting ability",
                    "Very Poor: Robot's shooting ability severely hampered, little to no accuracy"
                ],
                "id": "ShooterDefenseRating"
            },
            {
                "type": "GenericTextArea",
                "text": "Rating Notes",
                "id": "RatingNotes"
            },
            {
                "type": "DarkButton",
                "text": "Submit",
                "id": "result"
            }
        ],
        "exports": {
            "delimiter": "|",
            "order": [
                "ScoutId",
                "MatchKey",
                "Alliance",
                "DriverStation",
                "TeamNumber",
                "StartingPosition",
                "AutoScoringSide",
                "AutoTrenchBump",
                "AutoClimb",
                "AutoNotes",
                "TeleopScoringSide",
                "ShootOnTheMove",
                "TeleopTrenchBump",
                "TeleopClimb",
                "ClimbSpeed",
                "TeleopNotes",
                "Disabled",
                "StabilityRating",
                "RobotStyleType",
                "DriverRating",
                "IntakeSpeed",
                "ThroughputSpeed",
                "DefenseRating",
                "IntakeDefenseRating",
                "ShooterDefenseRating",
                "RatingNotes"
            ]
        }
    },
    {
        "name": "2026 Pit Scouting App",
        "description": "Team 4099: The Falcon's 2026 pit scouting app for pit data collection.",
        "components": [
            {
                "type": "GenericHeaderOne",
                "text": "2026 Pit Scouting App"
            },
            {
                "type": "GenericTextInput",
                "text": "Scout Name",
                "placeholder": [
                    "Yusuf"
                ],
                "required": true,
                "id": "ScoutId"
            },
            {
                "type": "GenericTextInput",
                "text": "Team Number",
                "placeholder": [
                    "9999"
                ],
                "required": true,
                "id": "TeamNumber"
            },
            {
                "type": "Spacing"
            },
            {
                "type": "GenericHeaderTwo",
                "text": "General Notes"
            },
            {
                "type": "GenericTextInput",
                "text": "What is their hopper capacity?",
                "placeholder": [
                  "32"
                ],
              "required": true,
              "id": "HopperCapacity"
            },
            {
                "type": "GenericTextInput",
                "text": "What is the weight of their robot without batteries & bumpers, in pounds",
                "placeholder": [
                    "115"
                ],
                "required": true,
                "id": "WeightOfRobot"
            },
            {
                "type": "GenericDropdown",
                "text": "Take a picture of the team's robot and put it in #upl_scouting_qrcodes?",
                "options": [
                    "Done",
                ],
                "id": "ConfirmPictureTaken",
                "required": true
            },
            {
                "type": "DarkButton",
                "text": "Submit",
                "id": "result"
            }
        ],
        "exports": {
            "delimiter": "|" ,
            "order": [
                "ScoutId",
                "TeamNumber",
                "HopperCapacity",
                "WeightOfRobot"
            ]
        }
    }
]
